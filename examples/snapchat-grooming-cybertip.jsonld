      "uco-core:description": {
        "@type": "xsd:string",
        "@value": "Rapid escalation pattern observed across three chat sessions: initial contact and age deception (Day 1), trust building and isolation through secrecy demands (Day 2), sexual solicitation and CSAM elicitation (Day 3)."
