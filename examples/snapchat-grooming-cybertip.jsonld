      "uco-core:name": "Snapchat Online Grooming Behavior",
      "uco-core:description": {
        "@type": "xsd:string",
        "@value": "Predatory grooming behavior conducted by adult offender targeting a 13-year-old child through Snapchat over three sessions spanning April 10-12, 2025. The offender used age deception, emotional manipulation, isolation tactics, and secrecy demands before escalating to sexual solicitation of images."
      },
