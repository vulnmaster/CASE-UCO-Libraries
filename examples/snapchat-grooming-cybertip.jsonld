      "uco-core:description": {
        "@type": "xsd:string",
        "@value": "CSAM incident in which a child victim produced self-generated sexually explicit imagery after being groomed and solicited by an online predator through Snapchat. The material was transmitted via the platform's messaging service."
      }
    },

    {
