  "@graph": [

    {
      "@id": "kb:bundle-f7c82a01-4b3e-4d5a-9c1f-8e2d3a4b5c6d",
      "@type": "uco-core:Bundle",
      "uco-core:name": "Snapchat Grooming and CyberTip Report (CAC Enhanced)",
      "uco-core:description": {
        "@type": "xsd:string",
        "@value": "Bundle modeling a grooming chat over Snapchat between an adult offender from Indiana and a child victim from Texas. The grooming occurred across three chat sessions (April 10-12, 2025), was detected by a Snapchat monitoring service, reported to NCMEC, and resulted in a CyberTip due to self-generated CSAM. Enhanced with Crimes Against Children (CAC) Ontology types. Three semantic layers: (1) observable evidence (Messages, Threads, Accounts, RasterPicture), (2) CAC behavioral interpretation (OnlineGrooming, GroomingPhases, GroomingMessage types), (3) institutional workflow (AutomatedDetectionAction, NCMECCybertipReport, CACInvestigation)."
      },
      "uco-core:object": [
