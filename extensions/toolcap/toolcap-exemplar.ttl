# Tools (instances of uco-tool:Tool)
# =============================================================================

kb:Tool-a1b2c3d4-e5f6-4a7b-8c9d-0e1f2a3b4c5d
	a uco-tool:Tool ;
	uco-core:name "Tool A"^^xsd:string ;
	uco-core:description "A digital forensics platform for acquiring, analyzing, and reporting on digital evidence from computers, mobile devices, and cloud services."^^xsd:string ;
	.

kb:Tool-b2c3d4e5-f6a7-4b8c-9d0e-1f2a3b4c5d6e
	a uco-tool:Tool ;
	uco-core:name "Tool B"^^xsd:string ;
	uco-core:description "A mobile forensics tool for physical and logical extraction and analysis of data from mobile devices, including smartphones, tablets, and portable GPS devices."^^xsd:string ;
	.


