	.

# --- Tool A / Outlook .nst on Windows 11 — fail ---
kb:Benchmark-ccc33333-3333-4333-a333-333333333333
	a toolcap:BenchmarkObservation ;
	uco-core:description "Benchmark of Tool A parsing Outlook .nst format on Windows 11. Tool failed to parse the new database format."^^xsd:string ;
	toolcap:capability kb:ToolCapability-22222222-3333-4444-a555-666666666666 ;
	toolcap:benchmarkDate "2026-03-15T14:00:00Z"^^xsd:dateTime ;
	toolcap:benchmarkedBy kb:Identity-lab-aaa11111-bbbb-4ccc-dddd-eeeeeeeeeeee ;
	toolcap:benchmarkPlatform kb:Platform-windows11-logical-44444444-aaaa-4bbb-cccc-dddddddddddd ;
	toolcap:parseSuccess "false"^^xsd:boolean ;
	toolcap:completenessScore "0.0"^^xsd:decimal ;
	toolcap:missedCategory "emails"^^xsd:string ;
	toolcap:missedCategory "contacts"^^xsd:string ;
	toolcap:missedCategory "calendar events"^^xsd:string ;
	toolcap:missedCategory "attachments"^^xsd:string ;
	toolcap:testedToolVersion "8.2.0"^^xsd:string ;
	toolcap:testedApplicationVersion "New (2024)"^^xsd:string ;
	toolcap:testedDataFormatVersion ".nst"^^xsd:string ;
	toolcap:benchmarkNotes "Tool A v8.2.0 cannot recognize the new Microsoft custom database format (.nst). Vendor has acknowledged the gap and indicated a parser update is planned for Q3 2026."^^xsd:string ;
	.

