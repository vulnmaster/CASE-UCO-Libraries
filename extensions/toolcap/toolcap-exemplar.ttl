# --- Tool A → App Alpha (Android physical + iOS logical) ---
kb:ToolCapability-11111111-2222-4333-a444-555555555555
	a toolcap:ToolCapability ;
	uco-core:description "Tool A's capability to extract and parse App Alpha messaging data from Android and iOS device images."^^xsd:string ;
	toolcap:tool kb:Tool-a1b2c3d4-e5f6-4a7b-8c9d-0e1f2a3b4c5d ;
	toolcap:application kb:Application-c3d4e5f6-a7b8-4c9d-0e1f-2a3b4c5d6e7f ;
	toolcap:supportsPlatform
		kb:Platform-android14-physical-11111111-aaaa-4bbb-cccc-dddddddddddd ,
		kb:Platform-ios17-logical-33333333-aaaa-4bbb-cccc-dddddddddddd ;
	toolcap:parsedObservableType "messages"^^xsd:string ;
	toolcap:parsedObservableType "contacts"^^xsd:string ;
	toolcap:parsedObservableType "media files"^^xsd:string ;
	toolcap:parsedObservableType "call logs"^^xsd:string ;
	toolcap:toolVersion "8.2.0"^^xsd:string ;
	toolcap:applicationVersion "7.0.2"^^xsd:string ;
	toolcap:claimedByVendor "true"^^xsd:boolean ;
	toolcap:verifiedByBenchmark "true"^^xsd:boolean ;
	toolcap:isVerified "true"^^xsd:boolean ;
	toolcap:lastTestedDate "2026-03-01T10:00:00Z"^^xsd:dateTime ;
	toolcap:hasAccessRestriction kb:AccessRestriction-commercial-55555555-aaaa-4bbb-cccc-dddddddddddd ;
	toolcap:hasObservation
		kb:Benchmark-aaa11111-1111-4111-a111-111111111111 ;
	.

