# =============================================================================
# Benchmark Observations
# =============================================================================

# --- Tool A / App Alpha on Android 14 physical — pass ---
kb:Benchmark-aaa11111-1111-4111-a111-111111111111
	a toolcap:BenchmarkObservation ;
	uco-core:description "Benchmark of Tool A parsing App Alpha on Android 14 physical extraction."^^xsd:string ;
	toolcap:capability kb:ToolCapability-11111111-2222-4333-a444-555555555555 ;
	toolcap:benchmarkDate "2026-03-01T10:00:00Z"^^xsd:dateTime ;
	toolcap:benchmarkedBy kb:Identity-lab-aaa11111-bbbb-4ccc-dddd-eeeeeeeeeeee ;
	toolcap:benchmarkPlatform kb:Platform-android14-physical-11111111-aaaa-4bbb-cccc-dddddddddddd ;
	toolcap:parseSuccess "true"^^xsd:boolean ;
	toolcap:completenessScore "0.95"^^xsd:decimal ;
	toolcap:accuracyScore "0.98"^^xsd:decimal ;
	toolcap:falsePositiveCount "2"^^xsd:nonNegativeInteger ;
	toolcap:falseNegativeCount "12"^^xsd:nonNegativeInteger ;
	toolcap:processingDuration "PT3M45S"^^xsd:duration ;
	toolcap:datasetSizeInBytes "5368709120"^^xsd:nonNegativeInteger ;
	toolcap:parsedCategory "messages"^^xsd:string ;
	toolcap:parsedCategory "contacts"^^xsd:string ;
	toolcap:parsedCategory "media files"^^xsd:string ;
	toolcap:parsedCategory "call logs"^^xsd:string ;
	toolcap:testedToolVersion "8.2.0"^^xsd:string ;
	toolcap:testedApplicationVersion "7.0.2"^^xsd:string ;
	toolcap:benchmarkNotes "Full physical image from Pixel 8. All major artifact categories recovered. 12 deleted messages not recovered."^^xsd:string ;
	.

