kb:Benchmark-autopsy-snapchat-7777aa00-1111-4777-f777-777777777777
	a toolcap:BenchmarkObservation ;
	uco-core:description "Benchmark of Autopsy parsing Snapchat iOS messages from main.db."^^xsd:string ;
	toolcap:capability kb:Capability-parse-snapchat-msgs-22222255-bbbb-4222-a222-222222222222 ;
	toolcap:benchmarkDate "2026-03-15T10:00:00Z"^^xsd:dateTime ;
	toolcap:benchmarkedBy kb:Identity-lab-aaa11111-bbbb-4ccc-dddd-eeeeeeeeeeee ;
	toolcap:benchmarkEnvironment kb:OS-ios-dddddddd-4444-4ddd-e444-444444444444 ;
	toolcap:benchmarkFramework "AutoDFBench"^^xsd:string ;
	toolcap:testCaseIdentifier "AutoDFBench-MSG-iOS-01"^^xsd:string ;
	toolcap:parseSuccess "true"^^xsd:boolean ;
	toolcap:groundTruthCount "500"^^xsd:nonNegativeInteger ;
	toolcap:submittedCount "478"^^xsd:nonNegativeInteger ;
	toolcap:truePositiveCount "475"^^xsd:nonNegativeInteger ;
	toolcap:falsePositiveCount "3"^^xsd:nonNegativeInteger ;
	toolcap:falseNegativeCount "25"^^xsd:nonNegativeInteger ;
	toolcap:precisionScore "0.9937"^^xsd:decimal ;
	toolcap:recallScore "0.95"^^xsd:decimal ;
	toolcap:f1Score "0.9714"^^xsd:decimal ;
	toolcap:completenessScore "0.95"^^xsd:decimal ;
	toolcap:accuracyScore "0.98"^^xsd:decimal ;
	toolcap:benchmarkSuiteScore "0.96"^^xsd:decimal ;
	toolcap:processingDuration "PT2M15S"^^xsd:duration ;
	toolcap:datasetSizeInBytes "1073741824"^^xsd:nonNegativeInteger ;
	toolcap:parsedCategory "messages"^^xsd:string ;
	toolcap:parsedCategory "contacts"^^xsd:string ;
	toolcap:missedCategory "stories"^^xsd:string ;
	toolcap:testedToolVersion "4.21.0"^^xsd:string ;
	toolcap:testedApplicationVersion "13.31.0.47"^^xsd:string ;
	toolcap:benchmarkNotes "Recovered 475 of 500 planted messages. Missed 25 deleted messages. 3 false positives from draft message fragments."^^xsd:string ;
	.

