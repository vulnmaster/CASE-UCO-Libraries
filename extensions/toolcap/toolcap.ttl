# Forensic Tool Capability Extension for CASE/UCO (OWL T-Box)
#
# This extension ontology models which digital forensic tools can parse
# which applications, on which platforms, for which observable types.
# It supports both vendor-claimed and independently benchmarked capability
# data through append-only BenchmarkObservation instances.
#
# v0.4.0 refactors the monolithic ToolCapability into a decomposed,
# graph-based model informed by Sean Barnum's data model:
#
#   Tool --(mayUse)--> Module --(hasCapability)--> Capability
#                      Module --(uses)--> Parser
#                      Module --(analyticFocus)--> Application
#   Application --(runs-on)--> OperatingSystem
#   Application --(variation-of)--> Application (generic)
#   Versioned instances --(isVersionOf)--> Generic instances
#
# The generic Capability class (proposed for uco-capability namespace)
# uses ActionPattern for structured characterization. This extension
# imports and extends it with forensic-specific benchmarking classes.
#
# Key changes from v0.3.x:
#   - ToolCapability deprecated in favor of generic Capability
#   - PlatformSpecification removed (use OperatingSystem + Relationships)
#   - Module and Parser added as Software subclasses
#   - CapabilityMatrix deprecated (the graph IS the matrix)
#   - BenchmarkObservation now links to Capability (not ToolCapability)
#   - AccessRestriction now links to Capability via Relationship
#
# Companion files:
#   toolcap-shapes.ttl   — SHACL property shapes for validation
#   toolcap-exemplar.ttl — Validated exemplar instances (A-Box)

@prefix toolcap: <http://example.org/ontology/toolcap/> .
@prefix capability: <https://proposed.ontology.unifiedcyberontology.org/uco/capability/> .
@prefix uco-core: <https://ontology.unifiedcyberontology.org/uco/core/> .
@prefix uco-tool: <https://ontology.unifiedcyberontology.org/uco/tool/> .
@prefix uco-action: <https://ontology.unifiedcyberontology.org/uco/action/> .
@prefix uco-marking: <https://ontology.unifiedcyberontology.org/uco/marking/> .
@prefix uco-observable: <https://ontology.unifiedcyberontology.org/uco/observable/> .
@prefix case-investigation: <https://ontology.caseontology.org/case/investigation/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/ontology/toolcap>
	a owl:Ontology ;
	rdfs:label "Forensic Tool Capability Extension"@en ;
	rdfs:comment "An extension ontology for the Cyber Domain Ontology (CDO) that provides classes and properties for modeling the capabilities of digital forensic tools and benchmarking their performance. This version (0.4.0) adopts a decomposed, graph-based model where capabilities are generic (not tool-specific), tools are related to modules and parsers via Relationships, and platform support is modeled using first-class OperatingSystem instances rather than custom PlatformSpecification objects. The decomposed model enables graph-based path-finding queries (e.g., 'which tool chain can produce text messages from iOS Snapchat?'), supports modular third-party assertions, and aligns with the proposed UCO Capability namespace. BenchmarkObservation instances provide append-only empirical evidence with standard IR metrics (precision, recall, F1) aligned with the NIST CFTT programme and AutoDFBench."@en ;
	owl:versionIRI toolcap:0.4.0 ;
	owl:priorVersion toolcap:0.3.1 ;
	owl:imports
		<https://proposed.ontology.unifiedcyberontology.org/uco/capability> ,
		<https://ontology.unifiedcyberontology.org/uco/core> ,
		<https://ontology.unifiedcyberontology.org/uco/tool> ,
		<https://ontology.unifiedcyberontology.org/uco/action> ,
		<https://ontology.unifiedcyberontology.org/uco/marking> ,
		<https://ontology.unifiedcyberontology.org/uco/observable> ,
		<https://ontology.caseontology.org/case/investigation> ;
	.


# =============================================================================
# Classes — retained and adapted
# =============================================================================

toolcap:BenchmarkObservation
	a owl:Class ;
	rdfs:subClassOf uco-core:Assertion ;
	rdfs:label "BenchmarkObservation"@en ;
	rdfs:comment "A benchmark observation is a single point-in-time record of testing a forensic tool's capability. It is a subclass of uco-core:Assertion because each observation is an empirical assertion about a tool's performance that is declared to be true by the benchmarking party. Each observation captures the results of one test run, including pass/fail outcome, completeness and accuracy metrics, standard information retrieval metrics (precision, recall, F1), confusion matrix counts (TP, FP, FN), processing performance, benchmark provenance (framework name, test case identifier, suite score), observable categories parsed or missed, tool and application versions tested, and the data format version. BenchmarkObservation instances are append-only: new test runs produce new instances rather than updating existing ones, preserving a full audit trail of capability evidence over time. The inherited uco-core:statement property from Assertion may carry a human-readable summary of the benchmark result. See https://doi.org/10.6028/NIST.SP.500-281 for the NIST CFTT benchmark methodology."@en ;
	.

toolcap:AccessRestriction
	a owl:Class ;
	rdfs:subClassOf uco-marking:MarkingDefinition ;
	rdfs:label "AccessRestriction"@en ;
	rdfs:comment "An access restriction is a marking definition that describes a security, licensing, classification, operational security, or legal authority constraint on the use of a forensic tool capability. It is a subclass of uco-marking:MarkingDefinition because access restrictions are a specific form of data marking that conveys restrictions, permissions, and guidance for how capability data can be used and shared — the same semantic purpose served by UCO's marking namespace. By subclassing MarkingDefinition, access restrictions integrate into UCO's standard marking pipeline: they can be applied to any UcoObject via the objectMarking property, and they inherit the definitionType property which aligns with restrictionType. The toolcap-specific properties (restrictionType, restrictionLevel, restrictionDescription) provide forensic-domain refinement beyond what the base MarkingDefinition offers. When a specific investigative authorization is required, the restriction can link to a case-investigation:Authorization instance via requiredAuthorization. See https://www.nist.gov/publications for related information security marking standards."@en ;
	.


# =============================================================================
# Deprecated classes (retained for backward compatibility, marked deprecated)
# =============================================================================

toolcap:ToolCapability
	a owl:Class ;
	rdfs:subClassOf uco-core:UcoObject ;
	rdfs:label "ToolCapability"@en ;
	rdfs:comment "DEPRECATED in 0.4.0. Use capability:Capability (proposed uco-capability:Capability) instead, linked to tools via uco-core:Relationship with kindOfRelationship='hasCapability'. A tool capability was a monolithic assertion that a specific digital forensic tool can parse data from a specific application. This class is retained for backward compatibility with v0.3.x graphs but should not be used in new data."@en ;
	owl:deprecated "true"^^xsd:boolean ;
	.

toolcap:CapabilityMatrix
	a owl:Class ;
	rdfs:subClassOf uco-core:ContextualCompilation ;
	rdfs:label "CapabilityMatrix"@en ;
	rdfs:comment "DEPRECATED in 0.4.0. The capability matrix concept is superseded by querying the overall graph of Tool, Module, Capability, and Relationship instances. A capability matrix was a named, versioned collection of ToolCapability assertions."@en ;
	owl:deprecated "true"^^xsd:boolean ;
	.

toolcap:PlatformSpecification
	a owl:Class ;
	rdfs:subClassOf uco-core:UcoObject ;
	rdfs:label "PlatformSpecification"@en ;
	rdfs:comment "DEPRECATED in 0.4.0. Use first-class uco-observable:OperatingSystem instances linked via uco-core:Relationship (kindOfRelationship='runs-on') instead. A platform specification was a custom object describing the operating system, OS version, device model, and extraction method(s)."@en ;
	owl:deprecated "true"^^xsd:boolean ;
	.


# =============================================================================
# Object Properties — BenchmarkObservation
# =============================================================================

toolcap:capability
	a owl:ObjectProperty ;
	rdfs:label "capability"@en ;
	rdfs:comment "Links a BenchmarkObservation to the Capability it provides evidence for. In v0.4.0 the range is the generic capability:Capability class."@en ;
	rdfs:domain toolcap:BenchmarkObservation ;
	rdfs:range capability:Capability ;
	.

toolcap:benchmarkedBy
	a owl:ObjectProperty ;
	rdfs:label "benchmarkedBy"@en ;
	rdfs:comment "Identifies the person or organization (an instance of uco-core:IdentityAbstraction) that performed this benchmark test."@en ;
	rdfs:domain toolcap:BenchmarkObservation ;
	rdfs:range uco-core:IdentityAbstraction ;
	.

toolcap:benchmarkEnvironment
	a owl:ObjectProperty ;
	rdfs:label "benchmarkEnvironment"@en ;
	rdfs:comment "Links a BenchmarkObservation to the OperatingSystem instance describing the environment in which the benchmark was conducted. Replaces the deprecated benchmarkPlatform property."@en ;
	rdfs:domain toolcap:BenchmarkObservation ;
	rdfs:range uco-observable:OperatingSystem ;
	.

toolcap:requiredAuthorization
	a owl:ObjectProperty ;
	rdfs:label "requiredAuthorization"@en ;
	rdfs:comment "Links an AccessRestriction to a case-investigation:Authorization instance when a specific investigative authorization (e.g., warrant, court order) is required to use the restricted capability."@en ;
	rdfs:domain toolcap:AccessRestriction ;
	rdfs:range case-investigation:Authorization ;
	.


# =============================================================================
# Deprecated Object Properties (retained for backward compat)
# =============================================================================

toolcap:tool
	a owl:ObjectProperty ;
	rdfs:label "tool"@en ;
	rdfs:comment "DEPRECATED in 0.4.0. Use uco-core:Relationship with kindOfRelationship='mayUse' or 'uses' to connect tools to modules/capabilities."@en ;
	rdfs:domain toolcap:ToolCapability ;
	rdfs:range uco-tool:Tool ;
	owl:deprecated "true"^^xsd:boolean ;
	.

toolcap:application
	a owl:ObjectProperty ;
	rdfs:label "application"@en ;
	rdfs:comment "DEPRECATED in 0.4.0. Use capability:analyticFocus on Module, or model the Application separately and link via Relationships."@en ;
	rdfs:domain toolcap:ToolCapability ;
	rdfs:range uco-observable:ObservableObject ;
	owl:deprecated "true"^^xsd:boolean ;
	.

toolcap:supportsPlatform
	a owl:ObjectProperty ;
	rdfs:label "supportsPlatform"@en ;
	rdfs:comment "DEPRECATED in 0.4.0. Use uco-core:Relationship with kindOfRelationship='runs-on' to link Applications to OperatingSystem instances."@en ;
	rdfs:domain toolcap:ToolCapability ;
	rdfs:range toolcap:PlatformSpecification ;
	owl:deprecated "true"^^xsd:boolean ;
	.

toolcap:hasObservation
	a owl:ObjectProperty ;
	rdfs:label "hasObservation"@en ;
	rdfs:comment "DEPRECATED in 0.4.0. Use the inverse property toolcap:capability on BenchmarkObservation to link observations to Capability instances."@en ;
	rdfs:domain toolcap:ToolCapability ;
	rdfs:range toolcap:BenchmarkObservation ;
	owl:deprecated "true"^^xsd:boolean ;
	.

toolcap:hasAccessRestriction
	a owl:ObjectProperty ;
	rdfs:label "hasAccessRestriction"@en ;
	rdfs:comment "DEPRECATED in 0.4.0. Use uco-core:Relationship with kindOfRelationship='hasAccessRestriction' instead."@en ;
	rdfs:domain toolcap:ToolCapability ;
	rdfs:range toolcap:AccessRestriction ;
	owl:deprecated "true"^^xsd:boolean ;
	.

toolcap:hasCapability
	a owl:ObjectProperty ;
	rdfs:label "hasCapability"@en ;
	rdfs:comment "DEPRECATED in 0.4.0. Use uco-core:Relationship with kindOfRelationship='hasCapability' instead."@en ;
	rdfs:domain toolcap:CapabilityMatrix ;
	rdfs:range toolcap:ToolCapability ;
	owl:deprecated "true"^^xsd:boolean ;
	.

toolcap:benchmarkPlatform
	a owl:ObjectProperty ;
	rdfs:label "benchmarkPlatform"@en ;
	rdfs:comment "DEPRECATED in 0.4.0. Use toolcap:benchmarkEnvironment instead."@en ;
	rdfs:domain toolcap:BenchmarkObservation ;
	rdfs:range toolcap:PlatformSpecification ;
	owl:deprecated "true"^^xsd:boolean ;
	.


# =============================================================================
# Datatype Properties — BenchmarkObservation (retained, well-designed)
# =============================================================================

toolcap:benchmarkDate
	a owl:DatatypeProperty ;
	rdfs:label "benchmarkDate"@en ;
	rdfs:comment "The date and time when this benchmark test was conducted."@en ;
	rdfs:domain toolcap:BenchmarkObservation ;
	rdfs:range xsd:dateTime ;
	.

toolcap:parseSuccess
	a owl:DatatypeProperty ;
	rdfs:label "parseSuccess"@en ;
	rdfs:comment "A boolean indicating whether the tool produced any usable output in this benchmark run."@en ;
	rdfs:domain toolcap:BenchmarkObservation ;
	rdfs:range xsd:boolean ;
	.

toolcap:completenessScore
	a owl:DatatypeProperty ;
	rdfs:label "completenessScore"@en ;
	rdfs:comment "The fraction of expected records the tool successfully recovered, 0.0 to 1.0."@en ;
	rdfs:domain toolcap:BenchmarkObservation ;
	rdfs:range xsd:decimal ;
	.

toolcap:accuracyScore
	a owl:DatatypeProperty ;
	rdfs:label "accuracyScore"@en ;
	rdfs:comment "The fidelity of the tool's recovered data, 0.0 to 1.0."@en ;
	rdfs:domain toolcap:BenchmarkObservation ;
	rdfs:range xsd:decimal ;
	.

toolcap:precisionScore
	a owl:DatatypeProperty ;
	rdfs:label "precisionScore"@en ;
	rdfs:comment "Precision = TP / (TP + FP), 0.0 to 1.0."@en ;
	rdfs:domain toolcap:BenchmarkObservation ;
	rdfs:range xsd:decimal ;
	.

toolcap:recallScore
	a owl:DatatypeProperty ;
	rdfs:label "recallScore"@en ;
	rdfs:comment "Recall = TP / (TP + FN), 0.0 to 1.0."@en ;
	rdfs:domain toolcap:BenchmarkObservation ;
	rdfs:range xsd:decimal ;
	.

toolcap:f1Score
	a owl:DatatypeProperty ;
	rdfs:label "f1Score"@en ;
	rdfs:comment "F1 = 2 * precision * recall / (precision + recall), 0.0 to 1.0."@en ;
	rdfs:domain toolcap:BenchmarkObservation ;
	rdfs:range xsd:decimal ;
	.

toolcap:truePositiveCount
	a owl:DatatypeProperty ;
	rdfs:label "truePositiveCount"@en ;
	rdfs:comment "The number of items correctly identified by the tool."@en ;
	rdfs:domain toolcap:BenchmarkObservation ;
	rdfs:range xsd:nonNegativeInteger ;
	.

toolcap:falsePositiveCount
	a owl:DatatypeProperty ;
	rdfs:label "falsePositiveCount"@en ;
	rdfs:comment "The number of items the tool reported that do not actually exist in the source data."@en ;
	rdfs:domain toolcap:BenchmarkObservation ;
	rdfs:range xsd:nonNegativeInteger ;
	.

toolcap:falseNegativeCount
	a owl:DatatypeProperty ;
	rdfs:label "falseNegativeCount"@en ;
	rdfs:comment "The number of items in the source data not recovered by the tool."@en ;
	rdfs:domain toolcap:BenchmarkObservation ;
	rdfs:range xsd:nonNegativeInteger ;
	.

toolcap:groundTruthCount
	a owl:DatatypeProperty ;
	rdfs:label "groundTruthCount"@en ;
	rdfs:comment "The total number of items in the ground truth dataset."@en ;
	rdfs:domain toolcap:BenchmarkObservation ;
	rdfs:range xsd:nonNegativeInteger ;
	.

toolcap:submittedCount
	a owl:DatatypeProperty ;
	rdfs:label "submittedCount"@en ;
	rdfs:comment "The total number of items reported by the tool. submittedCount = TP + FP."@en ;
	rdfs:domain toolcap:BenchmarkObservation ;
	rdfs:range xsd:nonNegativeInteger ;
	.

toolcap:processingDuration
	a owl:DatatypeProperty ;
	rdfs:label "processingDuration"@en ;
	rdfs:comment "Wall-clock time for the benchmark run, expressed as xsd:duration."@en ;
	rdfs:domain toolcap:BenchmarkObservation ;
	rdfs:range xsd:duration ;
	.

toolcap:datasetSizeInBytes
	a owl:DatatypeProperty ;
	rdfs:label "datasetSizeInBytes"@en ;
	rdfs:comment "Size of the test dataset in bytes."@en ;
	rdfs:domain toolcap:BenchmarkObservation ;
	rdfs:range xsd:nonNegativeInteger ;
	.

toolcap:parsedCategory
	a owl:DatatypeProperty ;
	rdfs:label "parsedCategory"@en ;
	rdfs:comment "An observable category successfully extracted in this benchmark run."@en ;
	rdfs:domain toolcap:BenchmarkObservation ;
	rdfs:range xsd:string ;
	.

toolcap:missedCategory
	a owl:DatatypeProperty ;
	rdfs:label "missedCategory"@en ;
	rdfs:comment "An observable category the tool failed to extract despite data being present."@en ;
	rdfs:domain toolcap:BenchmarkObservation ;
	rdfs:range xsd:string ;
	.

toolcap:benchmarkNotes
	a owl:DatatypeProperty ;
	rdfs:label "benchmarkNotes"@en ;
	rdfs:comment "Free-text notes about this benchmark run."@en ;
	rdfs:domain toolcap:BenchmarkObservation ;
	rdfs:range xsd:string ;
	.

toolcap:testedToolVersion
	a owl:DatatypeProperty ;
	rdfs:label "testedToolVersion"@en ;
	rdfs:comment "The exact version string of the forensic tool used in this benchmark run."@en ;
	rdfs:domain toolcap:BenchmarkObservation ;
	rdfs:range xsd:string ;
	.

toolcap:testedApplicationVersion
	a owl:DatatypeProperty ;
	rdfs:label "testedApplicationVersion"@en ;
	rdfs:comment "The version of the target application whose data was used in this benchmark run."@en ;
	rdfs:domain toolcap:BenchmarkObservation ;
	rdfs:range xsd:string ;
	.

toolcap:testedDataFormatVersion
	a owl:DatatypeProperty ;
	rdfs:label "testedDataFormatVersion"@en ;
	rdfs:comment "The data storage format version tested (e.g., '.pst', '.nst', 'SQLite WAL v2')."@en ;
	rdfs:domain toolcap:BenchmarkObservation ;
	rdfs:range xsd:string ;
	.

toolcap:benchmarkFramework
	a owl:DatatypeProperty ;
	rdfs:label "benchmarkFramework"@en ;
	rdfs:comment "The name of the benchmarking framework (e.g., 'AutoDFBench', 'NIST-CFTT')."@en ;
	rdfs:domain toolcap:BenchmarkObservation ;
	rdfs:range xsd:string ;
	.

toolcap:testCaseIdentifier
	a owl:DatatypeProperty ;
	rdfs:label "testCaseIdentifier"@en ;
	rdfs:comment "A unique identifier for the specific test case within the benchmark framework."@en ;
	rdfs:domain toolcap:BenchmarkObservation ;
	rdfs:range xsd:string ;
	.

toolcap:benchmarkSuiteScore
	a owl:DatatypeProperty ;
	rdfs:label "benchmarkSuiteScore"@en ;
	rdfs:comment "An overall composite score from the benchmark framework, 0.0 to 1.0."@en ;
	rdfs:domain toolcap:BenchmarkObservation ;
	rdfs:range xsd:decimal ;
	.


# =============================================================================
# Datatype Properties — AccessRestriction (retained)
# =============================================================================

toolcap:restrictionType
	a owl:DatatypeProperty ;
	rdfs:subPropertyOf uco-marking:definitionType ;
	rdfs:label "restrictionType"@en ;
	rdfs:comment "The category of access restriction (e.g., 'licensing', 'classification', 'operational-security', 'legal-authority'). Subproperty of uco-marking:definitionType, ensuring that setting restrictionType also satisfies the MarkingDefinition requirement for a definitionType value."@en ;
	rdfs:domain toolcap:AccessRestriction ;
	rdfs:range xsd:string ;
	.

toolcap:restrictionLevel
	a owl:DatatypeProperty ;
	rdfs:label "restrictionLevel"@en ;
	rdfs:comment "The specific level or value of the restriction (e.g., 'commercial-license-required', 'law-enforcement-only')."@en ;
	rdfs:domain toolcap:AccessRestriction ;
	rdfs:range xsd:string ;
	.

toolcap:restrictionDescription
	a owl:DatatypeProperty ;
	rdfs:label "restrictionDescription"@en ;
	rdfs:comment "A human-readable explanation of the restriction."@en ;
	rdfs:domain toolcap:AccessRestriction ;
	rdfs:range xsd:string ;
	.


# =============================================================================
# Deprecated Datatype Properties (retained for backward compat)
# =============================================================================

toolcap:supportedPlatform
	a owl:DatatypeProperty ;
	rdfs:label "supportedPlatform"@en ;
	rdfs:comment "DEPRECATED in 0.2.0. Use uco-core:Relationship with kindOfRelationship='runs-on' and OperatingSystem instances."@en ;
	rdfs:domain toolcap:ToolCapability ;
	rdfs:range xsd:string ;
	owl:deprecated "true"^^xsd:boolean ;
	.

toolcap:parsedObservableType
	a owl:DatatypeProperty ;
	rdfs:label "parsedObservableType"@en ;
	rdfs:comment "DEPRECATED in 0.4.0. Model parsed observable types as result objects on the ActionPattern within the Capability's structuredCharacterization."@en ;
	rdfs:domain toolcap:ToolCapability ;
	rdfs:range xsd:string ;
	owl:deprecated "true"^^xsd:boolean ;
	.

toolcap:toolVersion
	a owl:DatatypeProperty ;
	rdfs:label "toolVersion"@en ;
	rdfs:comment "DEPRECATED in 0.4.0. Use separate Tool instances linked via Relationship (kindOfRelationship='isVersionOf')."@en ;
	rdfs:domain toolcap:ToolCapability ;
	rdfs:range xsd:string ;
	owl:deprecated "true"^^xsd:boolean ;
	.

toolcap:isVerified
	a owl:DatatypeProperty ;
	rdfs:label "isVerified"@en ;
	rdfs:comment "DEPRECATED in 0.4.0. Verification status is inferred from the presence of BenchmarkObservation instances."@en ;
	rdfs:domain toolcap:ToolCapability ;
	rdfs:range xsd:boolean ;
	owl:deprecated "true"^^xsd:boolean ;
	.

toolcap:lastTestedDate
	a owl:DatatypeProperty ;
	rdfs:label "lastTestedDate"@en ;
	rdfs:comment "DEPRECATED in 0.4.0. Query the most recent BenchmarkObservation's benchmarkDate instead."@en ;
	rdfs:domain toolcap:ToolCapability ;
	rdfs:range xsd:dateTime ;
	owl:deprecated "true"^^xsd:boolean ;
	.

toolcap:claimedByVendor
	a owl:DatatypeProperty ;
	rdfs:label "claimedByVendor"@en ;
	rdfs:comment "DEPRECATED in 0.4.0. Model vendor claims as separate assertions with provenance."@en ;
	rdfs:domain toolcap:ToolCapability ;
	rdfs:range xsd:boolean ;
	owl:deprecated "true"^^xsd:boolean ;
	.

toolcap:verifiedByBenchmark
	a owl:DatatypeProperty ;
	rdfs:label "verifiedByBenchmark"@en ;
	rdfs:comment "DEPRECATED in 0.4.0. Inferred from the presence of BenchmarkObservation instances."@en ;
	rdfs:domain toolcap:ToolCapability ;
	rdfs:range xsd:boolean ;
	owl:deprecated "true"^^xsd:boolean ;
	.

toolcap:applicationVersion
	a owl:DatatypeProperty ;
	rdfs:label "applicationVersion"@en ;
	rdfs:comment "DEPRECATED in 0.4.0. Use separate Application instances linked via Relationship (kindOfRelationship='isVersionOf')."@en ;
	rdfs:domain toolcap:ToolCapability ;
	rdfs:range xsd:string ;
	owl:deprecated "true"^^xsd:boolean ;
	.

toolcap:dataFormatVersion
	a owl:DatatypeProperty ;
	rdfs:label "dataFormatVersion"@en ;
	rdfs:comment "DEPRECATED in 0.4.0. Model data formats as ObservableObject instances."@en ;
	rdfs:domain toolcap:ToolCapability ;
	rdfs:range xsd:string ;
	owl:deprecated "true"^^xsd:boolean ;
	.

toolcap:forensicTaskType
	a owl:DatatypeProperty ;
	rdfs:label "forensicTaskType"@en ;
	rdfs:comment "DEPRECATED in 0.4.0. Use the ActionPattern name on the Capability's structuredCharacterization (e.g., 'file-carving', 'string-search')."@en ;
	rdfs:domain toolcap:ToolCapability ;
	rdfs:range xsd:string ;
	owl:deprecated "true"^^xsd:boolean ;
	.

toolcap:matrixName
	a owl:DatatypeProperty ;
	rdfs:label "matrixName"@en ;
	rdfs:comment "DEPRECATED in 0.4.0. CapabilityMatrix is deprecated."@en ;
	rdfs:domain toolcap:CapabilityMatrix ;
	rdfs:range xsd:string ;
	owl:deprecated "true"^^xsd:boolean ;
	.

toolcap:matrixVersion
	a owl:DatatypeProperty ;
	rdfs:label "matrixVersion"@en ;
	rdfs:comment "DEPRECATED in 0.4.0. CapabilityMatrix is deprecated."@en ;
	rdfs:domain toolcap:CapabilityMatrix ;
	rdfs:range xsd:string ;
	owl:deprecated "true"^^xsd:boolean ;
	.

toolcap:operatingSystem
	a owl:DatatypeProperty ;
	rdfs:label "operatingSystem"@en ;
	rdfs:comment "DEPRECATED in 0.4.0. PlatformSpecification is deprecated."@en ;
	rdfs:domain toolcap:PlatformSpecification ;
	rdfs:range xsd:string ;
	owl:deprecated "true"^^xsd:boolean ;
	.

toolcap:osVersion
	a owl:DatatypeProperty ;
	rdfs:label "osVersion"@en ;
	rdfs:comment "DEPRECATED in 0.4.0. PlatformSpecification is deprecated."@en ;
	rdfs:domain toolcap:PlatformSpecification ;
	rdfs:range xsd:string ;
	owl:deprecated "true"^^xsd:boolean ;
	.

toolcap:deviceModel
	a owl:DatatypeProperty ;
	rdfs:label "deviceModel"@en ;
	rdfs:comment "DEPRECATED in 0.4.0. PlatformSpecification is deprecated."@en ;
	rdfs:domain toolcap:PlatformSpecification ;
	rdfs:range xsd:string ;
	owl:deprecated "true"^^xsd:boolean ;
	.

toolcap:extractionMethod
	a owl:DatatypeProperty ;
	rdfs:label "extractionMethod"@en ;
	rdfs:comment "DEPRECATED in 0.4.0. PlatformSpecification is deprecated."@en ;
	rdfs:domain toolcap:PlatformSpecification ;
	rdfs:range xsd:string ;
	owl:deprecated "true"^^xsd:boolean ;
	.

toolcap:fileSystemType
	a owl:DatatypeProperty ;
	rdfs:label "fileSystemType"@en ;
	rdfs:comment "DEPRECATED in 0.4.0. PlatformSpecification is deprecated."@en ;
	rdfs:domain toolcap:PlatformSpecification ;
	rdfs:range xsd:string ;
	owl:deprecated "true"^^xsd:boolean ;
	.
